# Base de datos (SQLite para desarrollo, PostgreSQL/Supabase para producción)
DATABASE_URL=sqlite:///./gestion_prest.db

# Para Supabase (producción):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Auth — OBLIGATORIO en producción: generá una clave larga y aleatoria
# Ejemplo: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar-esta-clave-en-produccion

ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# CORS — URL del frontend en producción (Vercel)
# Varias URLs separadas por coma: https://mi-app.vercel.app,https://mi-dominio.com
ALLOWED_ORIGINS=https://mi-app.vercel.app
